# ── Project Results & Data ───────────────────────────────────────────────────
# Track the Result directory itself but ignore all generated output files.
Project/Result/*
!Project/Result/.gitkeep

# Ignore bulky dataset folders
Project/data/*
!Project/data/*.py
!Project/data/dataset_config.py
